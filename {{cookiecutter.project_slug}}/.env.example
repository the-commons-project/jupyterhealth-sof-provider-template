# JupyterHealth Exchange
JHE_URL={{ cookiecutter.jhe_base_url }}

# JHE_TOKEN is optional. Leave it blank to mint a JHE token from the SMART launch
# via token exchange (the provider authenticates into the EHR once, no second login).
# Set it to a static token only as a dev/test shortcut.
JHE_TOKEN=

# Optional: issuer presented to JHE on token exchange. Defaults to the EHR FHIR base;
# override when JHE trusts an issuer that differs from the FHIR base (e.g. a proxy).
# JHE_TRUSTED_ISS=

# EHR MRN identifier system (find this in your Epic Patient.identifier)
MRN_IDENTIFIER_SYSTEM={{ cookiecutter.mrn_identifier_system }}

# Optional: override data-type -> OMH code mapping as JSON
# JHE_DATA_TYPE_CODES={"steps": "omh:step-count:3.0"}
