# JupyterHealth Exchange
JHE_URL={{ cookiecutter.jhe_base_url }}
JHE_TOKEN=

# EHR MRN identifier system (find this in your Epic Patient.identifier)
MRN_IDENTIFIER_SYSTEM={{ cookiecutter.mrn_identifier_system }}

# Optional: override data-type -> OMH code mapping as JSON
# JHE_DATA_TYPE_CODES={"steps": "omh:step-count:3.0"}
