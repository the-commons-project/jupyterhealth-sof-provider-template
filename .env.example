# Copy to .env (gitignored) and fill in. Do NOT commit .env.
# The app mints its JHE token at launch by exchanging the EHR id_token (RFC 8693),
# so there is normally no token to paste here — JHE_TOKEN is a dev-only shortcut.
JHE_URL=https://jhe.example.org
JHE_TOKEN=
SMART_CLIENT_ID=00000000-0000-0000-0000-000000000000
SMART_SCOPES=openid fhirUser launch patient/*.read
EHR_IFRAME_ORIGIN=https://app.medplum.com
MRN_IDENTIFIER_SYSTEM=https://example.org/mrn

# Optional: the EHR issuer JHE must trust for the id_token exchange.
# JHE_TRUSTED_ISS=
